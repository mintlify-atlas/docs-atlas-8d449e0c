  "keyFeatures": [
    "User authentication with bcrypt password hashing",
    "Complete CRUD operations for products, categories, and users",
    "Session-based access control with express-session",
    "SQLite database with Sequelize ORM",
    "Server-side rendering with EJS templates",
    "RESTful routing with method-override for PUT/DELETE"
  ],
  "publicApiSurface": [
    "GET /entrar - Login page",
    "POST /entrar - Authenticate user",
    "GET /registrar - Registration page",
    "POST /registrar - Create new account",
    "POST /sair - Logout",
    "GET / - Home page (protected)",
    "GET /produtos - List all products (protected)",
    "POST /produtos - Create product (protected)",
    "GET /produtos/:id - View product details (protected)",
    "PUT /produtos/:id - Update product (protected)",
    "DELETE /produtos/:id - Delete product (protected)",
    "GET /categorias - List all categories (protected)",
    "POST /categorias - Create category (protected)",
    "PUT /categorias/:id - Update category (protected)",
    "DELETE /categorias/:id - Delete category (protected)",
    "GET /usuarios - List all users (protected)",
    "PUT /usuarios/:id - Update user (protected)",
    "DELETE /usuarios/:id - Delete user (protected)"
  ]
}
